// models.jsonc — per-user server config
// Copy to ~/.localllm/models.jsonc and edit as needed
// This file is NOT tracked in git.

{
  // Global defaults — overridden per-server below
  "defaults": {
    // === KV Cache Compression (pick one strategy) ===
    //
    // Option A: TurboQuant (feature/turboquant-kv-cache branch)
    // PolarQuant + Hadamard rotation. 3-bit recommended.
    // "turboKvBits": 3,
    // "turboFp16Layers": 1,
    // "turboVBits": null,
    //
    // Option B: Mixed-Quant (feature/mixed-quant-kv-cache branch)
    // Apple native mx.quantized_matmul. Recommended over TurboQuant.
    // Pattern: "Kbits,Vbits" — K is usually higher precision than V
    //   "8,4" = balanced (good quality, ~2x compression)
    //   "8,2" = aggressive (max compression, slight quality trade-off)
    //   "4,4" = extreme (lowest memory, quality may suffer)
    // "kvCacheQuantization": "8,4",
    // "kvGroupSize": 64,
    // "quantizedKvStart": 5000,
    // "kvCacheQuantizeAfterPrefill": false,
    //
    // Disk-backed prompt cache (survives server restarts)
    // "promptCacheDir": "$HOME/.localllm/prompt_cache",
    //
    // Option C: Vanilla (official/main branch)
    // No KV compression — full FP16 KV cache.
    // Leave all KV params commented out.

    // TurboQuant KV cache compression bits (1-4, uses PolarQuant + Hadamard)
    // 3-bit recommended by upstream. Lower = more compression, slight quality trade-off.
    "turboKvBits": 3,

    // Number of first/last layers to keep FP16 when using TurboQuant (default: 1)
    "turboFp16Layers": 1,

    // Use standard affine quantization for values at the given bit width
    // instead of PolarQuant. Leave null to use PolarQuant for both K and V.
    "turboVBits": null,

    // Prompt cache: max KV caches held in RAM
    "promptCacheSize": 12,

    // Prompt cache: hard byte limit for cached KV.
    // Prevents cache from eating all memory headroom.
    // Machine-specific: 48GB → 8GB (8589934592), 96GB → 24GB, 128GB → 20GB
    "promptCacheBytes": 21474836480,

    // Parallel decode slots and prefill workers
    // 6 is the memory-safe limit for 27B on 128GB M5 Max.
    // Active KV is fp16 (64 KB/token), 6 @ 100K avg = 39 GB active KV.
    // See memory-budget.py for full analysis.
    // For 48GB machines: decodeConcurrency=24, prefillConcurrency=4, prefillStepSize=1024
    "decodeConcurrency": 6,
    "prefillConcurrency": 8,
    "prefillStepSize": 2048,

    // Sampling defaults — aligned with Unsloth Qwen3.6 recommendations
    // Thinking mode (general): temp=1.0, top_p=0.95, top_k=20
    // Coding mode: temp=0.6, presence_penalty=0.0 (set per-request)
    "temperature": 1.0,
    "topP": 0.95,
    "topK": 20,
    "maxTokens": 4096,

    // Chat template kwargs passed to tokenizer.apply_chat_template()
    // enable_thinking: turn thinking on/off (default: true)
    // preserve_thinking: keep thinking trace from previous turns (Qwen3.6)
    "chatTemplateArgs": {
      "enable_thinking": true,
      "preserve_thinking": true
    }
  },

  // Per-server config
  "servers": {
    // Dense 27B — disabled by default, enable for comparison
    "dense": {
      "enabled": false,
      "model": "Qwen3.6-27B-UD-MLX-4bit",
      "port": 30090,
      "logFile": "dense.log"
      // No overrides needed — inherits all defaults above
    },

    // MoE 35B-A3B — primary model
    "moe": {
      "enabled": true,
      "model": "Qwen3.6-35B-A3B-UD-MLX-4bit",
      "port": 30083,
      "logFile": "moe.log"
      // "logLevel": "DEBUG",
      // Override per-server as needed, e.g.:
      // "turboKvBits": 4,
      // "promptCacheSize": 30,
      // "decodeConcurrency": 16,
      // "promptCacheBytes": 8589934592,  // 8GB cap — lower if OOM
    }
  },

  // Paths (usually don't need to change)
  "modelDir": "$HOME/.localllm/models",
  "pidDir": "$HOME/.localllm/pids",
  "cacheDir": "$HOME/.localllm/prompt_cache",
  "logDir": "$HOME/.localllm"
}
