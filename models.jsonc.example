// models.jsonc — per-user server config
// Copy to ~/.localllm/models.jsonc and edit as needed
// This file is NOT tracked in git.

{
  // Global defaults — overridden per-server below
  "defaults": {
    // KV cache quantization: [K_bits, V_bits], valid values: 2, 4, 8
    // 8,2 = K8+V2, -20% memory, tested identical quality
    // 8,4 = K8+V4, -18% memory, safer bet
    "kvQuant": [8, 2],

    // Only quantize caches with >= N tokens (short prefills stay fp16)
    "kvQuantStart": 1024,

    // Prompt cache: max KV caches held in RAM
    "promptCacheSize": 12,

    // Prompt cache: hard byte limit for cached KV.
    // With K8,V2 quantization: ~22 KB/token cached. 12 convos @ 75K avg = ~20 GB.
    // Prevents cache from eating all memory headroom.
    // Machine-specific: 48GB → 8GB (8589934592), 96GB → 24GB, 128GB → 20GB
    "promptCacheBytes": 21474836480,

    // Prompt cache: max disk entries (survives restart)
    "promptCacheDiskSize": 100,

    // Parallel decode slots and prefill workers
    // 6 is the memory-safe limit for 27B on 128GB M5 Max.
    // Active KV is fp16 (64 KB/token), 6 @ 100K avg = 39 GB active KV.
    // See memory-budget.py for full analysis.
    // For 48GB machines: decodeConcurrency=24, prefillConcurrency=4, prefillStepSize=1024
    "decodeConcurrency": 6,
    "prefillConcurrency": 8,
    "prefillStepSize": 2048,

    // Sampling defaults
    "temperature": 0.0,
    "maxTokens": 4096,

    // Chat template kwargs passed to tokenizer.apply_chat_template()
    "chatTemplateArgs": {
      "enable_thinking": true
    }
  },

  // Per-server config
  "servers": {
    // Dense 27B — disabled by default, enable for comparison
    "dense": {
      "enabled": false,
      "model": "Qwen3.6-27B-UD-MLX-4bit",
      "port": 30090,
      "logFile": "dense.log"
      // No overrides needed — inherits all defaults above
    },

    // MoE 35B-A3B — primary model
    "moe": {
      "enabled": true,
      "model": "Qwen3.6-35B-A3B-UD-MLX-4bit",
      "port": 30083,
      "logFile": "moe.log"
      // Override per-server as needed, e.g.:
      // "kvQuant": [8, 4],
      // "promptCacheSize": 30,
      // "decodeConcurrency": 16,
      // "promptCacheBytes": 8589934592,  // 8GB cap — lower if OOM
    }
  },

  // Paths (usually don't need to change)
  "modelDir": "$HOME/.localllm/models",
  "pidDir": "$HOME/.localllm/pids",
  "cacheDir": "$HOME/.localllm/prompt_cache",
  "logDir": "$HOME/.localllm"
}
